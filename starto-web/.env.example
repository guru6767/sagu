# starto-web/.env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API (Spring Boot)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8082

# ── Firebase Web SDK (required — all 6 must be set) ──────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps → Web app → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789

# ── Firebase Analytics (optional) ────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Razorpay (optional — only required for subscription/payment pages) ────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx

# ── Google Maps (optional — only required for Nearby map page) ────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_api_key
