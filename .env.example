# =============================================================
# Starto – Environment Variables Reference
# Copy this file to .env and fill in the values
# =============================================================

# ─── Database ────────────────────────────────────────────────
POSTGRES_DB=starto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password

# ─── Backend DB connection (used inside containers) ──────────
DB_URL=jdbc:postgresql://postgres:5432/starto
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Backend Server ──────────────────────────────────────────
# Fix #1: canonical port is 8080. Change PORT=8081 only for local legacy.
PORT=8080

# Fix #7: ddl-auto is 'validate' in prod. Override to 'update' for local dev only.
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ─── Firebase (Backend – service account) ──────────────────────────────────
# Fix #6: Preferred method for containers/Antigravity = base64-encoded JSON.
# Generate: base64 -w 0 firebase-service-account.json  (Linux/Mac)
#           [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-service-account.json"))  (PowerShell)
# Leave blank to fall back to FIREBASE_CONFIG_PATH (local dev only).
FIREBASE_SERVICE_ACCOUNT_B64=

# Local dev fallback (only used when FIREBASE_SERVICE_ACCOUNT_B64 is empty)
FIREBASE_CONFIG_PATH=src/main/resources/firebase-service-account.json

# ─── Firebase (Frontend – client SDK) ────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Google AI / Maps ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
OPENAI_API_KEY=dummy_key

# ─── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Razorpay Plan IDs
RAZORPAY_PLAN_SPRINT=plan_xxxx
RAZORPAY_PLAN_BOOST=plan_xxxx
RAZORPAY_PLAN_PRO=plan_xxxx
RAZORPAY_PLAN_CAPTAIN=plan_xxxx
RAZORPAY_PLAN_CAPTAIN_PRO=plan_xxxx
RAZORPAY_PLAN_PRO_PLUS=plan_xxxx
RAZORPAY_PLAN_GROWTH=plan_xxxx
RAZORPAY_PLAN_ANNUAL=plan_xxxx

# ─── Email / SMTP ────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# ─── Frontend API Base URL ───────────────────────────────────
# For Docker Compose (internal network):  http://backend:8080
# For Antigravity public deploy:          https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://backend:8080
